{
    # Global options
    email {$EMAIL}
}

# Dashboard & API Proxy
{$DOMAIN:localhost} {
    # Frontend Next.js Standalone
    reverse_proxy apex-frontend:3000

    # Backend API
    handle /api/* {
        reverse_proxy apex-backend:8000
    }

    # Backend WebSocket
    handle /ws {
        reverse_proxy apex-backend:8000
    }

    # Security Headers
    header {
        # Enable HSTS
        Strict-Transport-Security "max-age=31536000;"
        # Prevent Clickjacking
        X-Frame-Options "DENY"
        # Prevent Sniffing
        X-Content-Type-Options "nosniff"
        # Referrer Policy
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    # Compression
    encode gzip zstd
}
