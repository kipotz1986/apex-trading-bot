# ==============================================================================
# APEX TRADING BOT — ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to .env and fill in your actual credentials.
# WARNING: Do NOT commit your .env file to version control.
# ==============================================================================

# === AI Provider Config ===
# Supported providers: openai, google, anthropic, xai
AI_PROVIDER=openai
# Specific model name from the provider
AI_MODEL=gpt-4o
# Primary API Key
AI_API_KEY=
# Fallback provider in case the primary one is down
AI_FALLBACK_PROVIDER=google
AI_FALLBACK_MODEL=gemini-2.0-flash
AI_FALLBACK_API_KEY=

# === Exchange Config ===
# Supported exchanges: bybit, binance, okx (via CCXT)
EXCHANGE_NAME=bybit
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
# Set to true for Testnet / Paper Trading (highly recommended for dev)
EXCHANGE_TESTNET=true

# === On-Chain Data (Free Providers) ===
# CoinGecko: Opsional, meningkatkan rate limit. Daftar di https://www.coingecko.com/en/api
COINGECKO_API_KEY=
# Etherscan: Free tier 5 req/detik. Daftar di https://etherscan.io/apis
ETHERSCAN_API_KEY=
# API Keys untuk sentimen / on-chain
# Blockchain.com & CryptoCompare: Tidak perlu API key (100% Free Public API)

# === Database & Infrastructure ===
# PostgreSQL + TimescaleDB connection
DATABASE_URL=postgresql://apex:apex_dev_password@localhost:5432/apex_trading
# Redis for cache and message broker
REDIS_URL=redis://localhost:6379/0
# ChromaDB (Vector Database) settings
CHROMADB_HOST=localhost
CHROMADB_PORT=8000

# === PostgreSQL Container Config ===
# Required for docker-compose startup
POSTGRES_USER=apex
POSTGRES_PASSWORD=apex_dev_password
POSTGRES_DB=apex_trading

# === Telegram Bot Config ===
# Token from @BotFather
TELEGRAM_BOT_TOKEN=
# Your personal or channel Chat ID
TELEGRAM_CHAT_ID=

# === Authentication & Security ===
# Secret for signing JWT tokens
JWT_SECRET=
# NextAuth specific secret for the dashboard
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
# Bcrypt hash of the admin password (see DEPLOYMENT.md Step 1.5)
ADMIN_PASSWORD_HASH=
# Base32 secret for 2FA (Google Authenticator)
TOTP_SECRET=
# AES-256 key for API credential encryption (Base64 encoded 32-byte)
ENCRYPTION_KEY=

# === Deployment (Production Only) ===
# Your domain for SSL certificate (Caddy)
DOMAIN=bot.yourdomain.com
# Notification email for Let's Encrypt certificates
EMAIL=admin@yourdomain.com

# === Application Settings ===
# environment: development, production, test
APP_ENV=development
# level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
TIMEZONE=Asia/Jakarta
